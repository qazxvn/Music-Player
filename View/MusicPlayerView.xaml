<Window x:Class="MusicPlayer.View.MusicPlayerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:MusicPlayer.View"
        mc:Ignorable="d"
        Title="MusicPlayerView" Height="500" Width="770"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#0F172A">
    <Window.Resources>
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#6366F1"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#4F46E5"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#4338CA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavigationButton" TargetType="Button">
        <Setter Property="Height" Value="42"/>
        <Setter Property="Width" Value="147"/>
        <Setter Property="Margin" Value="0,4"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="HorizontalContentAlignment"
                Value="Stretch"/>
    </Style>

</Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Column="0"
                Grid.Row="0"
                Margin="4"
                Background="#1E293B"
                CornerRadius="12">

            <Grid Margin="12">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="🎵 Music Player"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="15"
                           Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1">

                    <Button Content="🎼 Плейлисты"
                            Command="{Binding ShowPlaylistsCommand}"
                            Height="38"
                            Margin="0,0,0,8"/>

                    <Button Content="🎧 Добавленные треки"
                            Command="{Binding AddedTrackCommand}"
                            Height="38"/>

                </StackPanel>
            </Grid>
        </Border>
        
        <Border Margin="4"
                Grid.Row="0"
                Grid.Column="1"
                Background="#1E293B"
                CornerRadius="12">
            
            <ListBox ItemsSource="{Binding Tracks}" SelectedItem="{Binding CurrentTrack, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#24324A"
                                CornerRadius="10"
                                Padding="10"
                                Margin="0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">

                                    <TextBlock Text="{Binding TrackName}"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="13"/>

                                    <TextBlock Text="{Binding Author}"
                                               Foreground="#94A3B8"
                                               FontSize="10"/>

                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding DataContext.DeleteTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Content="✕"
                                        Width="26"
                                        Height="26"
                                        Margin="8,0,0,0"
                                        Background="#334155"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        
        <Border Grid.Row="0"
                Grid.Column="2"
                Margin="4"
                Background="#1E293B"
                CornerRadius="12">
            
            <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Плейлисты"
                   Foreground="White"
                   FontWeight="SemiBold"
                   FontSize="16"
                   Margin="12"/>

        <ListBox Grid.Row="1"
                 Margin="8,0,8,8"
                 ItemsSource="{Binding Playlists}"
                 SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#24324A"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding DataContext.ShowCurrentPlaylistTracksCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding PlaylistName}"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="13"/>

                            <Button Grid.Column="1"
                                    Command="{Binding DataContext.DeletePlaylistCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    Content="✕"
                                    Width="26"
                                    Height="26"
                                    Margin="8,0,0,0"
                                    Background="#334155"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
        </Border>
        
        <Border Grid.Column="0"
                Grid.Row="1"
                Margin="4"
                Background="#1E293B"
                CornerRadius="12">
            <StackPanel Margin="8">

                <Button Click="ShowAddTrackForm_Click"
                        Height="25"
                        Margin="0,0,0,6">
                    ➕ Добавить трек
                </Button>
                <Button Click="CreateNewPlaylist"
                        Height="25"
                        Margin="0,0,0,6">
                    📁 Создать плейлист
                </Button>
                <Button Click="AddTrackInPlaylist"
                        Height="25">
                    🎵 В плейлист
                </Button>
            </StackPanel>
        </Border>
        
        <Border Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" Margin="2" Background="#1E293B" CornerRadius="18">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> 
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/> 
                <ColumnDefinition Width="Auto"/> 
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                    Text="{Binding CurrentSliderPos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=\{0:mm\\:ss\}}" 
                    VerticalAlignment="Bottom" Margin="8"/>

            <Grid Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> 
                    <RowDefinition Height="Auto"/> 
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Button Command="{Binding PreviousTrackCommand}" Height="45" Width="45" Content="⏪" Margin="0,0,10,0"/>
                    <Button Command="{Binding PlayTrackCommand}" Height="60" Width="60" Content="⏯️"/>
                    <Button Command="{Binding NextTrackCommand}" Height="45" Width="45" Content="⏩" Margin="10,0,0,0"/>
                </StackPanel>

                <Slider Grid.Row="1" Height="20" Margin="0 10 0 0" Value="{Binding CurrentSliderPos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        LostMouseCapture="OnMouseCapture" 
                        Minimum="0" Maximum="{Binding MaximumTrackLength}" 
                        HorizontalAlignment="Stretch"/>
            </Grid>

            <TextBlock Grid.Column="2" 
                    Text="{Binding MaximumTrackLength, StringFormat=\{0:mm\\:ss\}}" 
                    VerticalAlignment="Bottom" Margin="8"/>

            <Slider Margin="-10 0 15 0" Grid.Column="3" Value="{Binding CurrentVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                LostMouseCapture="OnVolumeChanged" 
                Orientation="Vertical" Height="80" Width="25" 
                VerticalAlignment="Center" Minimum="0" Maximum="1.0"/>
        </Grid>
    </Border>
    </Grid>
</Window>
